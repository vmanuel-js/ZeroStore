<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_logo_white"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_logo_white_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Zero">
        <activity
            android:name=".pages.chat.ChatActivity"
            android:exported="false"
            android:label="@string/title_activity_chat"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.grafico.GraficoStockActivity"
            android:exported="false"
            android:label="@string/title_activity_grafico_stock"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.mapa_general.MapaGeneralActivity"
            android:exported="false"
            android:label="@string/title_activity_mapa_general"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.detalle_tienda.DetalleTiendaActivity"
            android:exported="false"
            android:label="@string/title_activity_detalle_tienda"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.mapa_individual.MapaIndividualActivity"
            android:exported="false"
            android:label="@string/title_activity_mapa_individual"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.tienda.TiendaActivity"
            android:exported="false"
            android:label="@string/title_activity_tienda"
            android:theme="@style/Theme.Zero" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".pages.admin.AdminProductosActivity"
            android:exported="false"
            android:label="@string/title_activity_admin_productos"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.App.Starting" />
        <activity
            android:name=".pages.colecciones.ColeccionesActivity"
            android:exported="false"
            android:label="@string/title_activity_colecciones"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.coleccion_detalle.ColeccionDetalleActivity"
            android:exported="false"
            android:label="@string/title_activity_colecciones"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.favoritos.FavoritosActivity"
            android:exported="false"
            android:label="@string/title_activity_favorito"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.perfil.ProfileActivity"
            android:exported="false"
            android:label="@string/title_activity_profile"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.carrito.CartActivity"
            android:exported="false"
            android:label="@string/title_activity_cart"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.detalle.ProductDetailActivity"
            android:exported="false"
            android:label="@string/title_activity_product_detail"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.initial.InitialActivity"
            android:exported="false"
            android:label="@string/title_activity_initial"
            android:theme="@style/Theme.Zero" />
        <activity
            android:name=".pages.login.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.Zero">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>